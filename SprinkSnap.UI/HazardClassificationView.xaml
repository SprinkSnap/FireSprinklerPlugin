<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.HazardClassificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI"
             Background="#EEF2F7">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4B5563" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D1D5DB" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#15803D" />
        <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RightAlignedCellText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0F172A"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="SprinkSnap AI-Assisted NFPA 13 Layout Review"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Auto-layout confident rooms, surface only exceptions, and keep final control with the sprinkler designer."
                               Foreground="#CBD5E1"
                               FontSize="13"
                               Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox Content="Review only exceptions"
                              Foreground="White"
                              IsChecked="{Binding ReviewOnlyExceptions}"
                              VerticalAlignment="Center"
                              Margin="0,0,18,0" />
                    <Button Content="Auto-Layout"
                            MinWidth="140"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AutoLayoutCommand}" />
                    <Button Content="Validate"
                            Command="{Binding ValidateCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Rooms" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding TotalRoomCount}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Extracted from Revit model" Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Exceptions" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding ExceptionRoomCount}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" />
                    <TextBlock Text="Need designer review or override" Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Auto-solved" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding AutoSolvedRoomCount}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" />
                    <TextBlock Text="Passed pre-placement validation" Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Average confidence" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding AverageConfidenceText}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Based on geometry and ceiling certainty" Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>
        </Grid>

        <TabControl Grid.Row="2"
                    Grid.RowSpan="2"
                    Margin="0,0,0,4"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="1  Project Setup">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Project sprinkler standard" Style="{StaticResource SectionTitle}" />
                                <TextBlock Grid.Row="1" Text="Set the default manufacturer and sprinkler head criteria for the project. SprinkSnap still filters by room hazard, ceiling, geometry, and listing constraints before recommending a head." Style="{StaticResource MutedText}" Margin="0,0,0,14" />
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Manufacturer" Style="{StaticResource LabelText}" /><ComboBox ItemsSource="{Binding ManufacturerOptions}" SelectedItem="{Binding SelectedManufacturer}" /></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,0,10"><TextBlock Text="Category" Style="{StaticResource LabelText}" /><ComboBox ItemsSource="{Binding CategoryOptions}" SelectedItem="{Binding SelectedCategory}" /></StackPanel>
                                    <StackPanel Grid.Row="1" Margin="0,0,10,0"><TextBlock Text="Orientation" Style="{StaticResource LabelText}" /><ComboBox ItemsSource="{Binding OrientationOptions}" SelectedItem="{Binding SelectedOrientation}" /></StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1"><TextBlock Text="K-factor" Style="{StaticResource LabelText}" /><ComboBox ItemsSource="{Binding KFactorOptions}" SelectedItem="{Binding SelectedKFactor}" /></StackPanel>
                                </Grid>
                                <Grid Grid.Row="3" Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.2*" /><ColumnDefinition Width="2*" /></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0"><TextBlock Text="Search model / SIN" Style="{StaticResource LabelText}" /><TextBox Text="{Binding SprinklerSearchText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="Selected model / SIN" Style="{StaticResource LabelText}" /><ComboBox DisplayMemberPath="DisplayName" ItemsSource="{Binding SprinklerFamilies}" SelectedItem="{Binding SelectedSprinklerFamily}" /></StackPanel>
                                </Grid>
                                <CheckBox Grid.Row="4" Content="Allow compatible alternate manufacturers for room overrides" IsChecked="{Binding AllowAlternateManufacturers}" Margin="0,16,0,0" />
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardBorder}"><StackPanel><TextBlock Text="Listing summary" Style="{StaticResource SectionTitle}" /><TextBlock Text="{Binding SelectedFamilyListingSummary}" Style="{StaticResource MutedText}" /></StackPanel></Border>
                        <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0,0,0,12"><StackPanel><TextBlock Text="Water supply / demand" Style="{StaticResource SectionTitle}" /><TextBlock Text="Static pressure PSI" Style="{StaticResource LabelText}" /><TextBox Text="{Binding StaticPressurePsi, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" /><TextBlock Text="Residual pressure PSI" Style="{StaticResource LabelText}" /><TextBox Text="{Binding ResidualPressurePsi, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" /><TextBlock Text="Flow GPM" Style="{StaticResource LabelText}" /><TextBox Text="{Binding FlowGpm, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="2  Rooms + Auto-Layout">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="220" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Room review and automatic layout" Style="{StaticResource SectionTitle}" /><TextBlock Text="Review extracted rooms, hazard, recommended heads, and layout status. Use Auto-Layout to solve confident rooms." Style="{StaticResource MutedText}" /></StackPanel><TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="12,10,8,0" VerticalAlignment="Top" /><Button Grid.Column="2" Content="Auto-Layout" Style="{StaticResource PrimaryButton}" Command="{Binding AutoLayoutCommand}" VerticalAlignment="Top" Margin="8,10,0,0" /><Button Grid.Column="3" Content="Validate" Command="{Binding ValidateCommand}" VerticalAlignment="Top" Margin="8,10,0,0" /></Grid></Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RoomsView}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False" SelectionMode="Extended" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" RowHeaderWidth="0" RowHeight="96" HeadersVisibility="Column" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Room" Width="2.1*" SortMemberPath="Number"><DataGridTemplateColumn.CellTemplate><DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}"><StackPanel Margin="8,6"><TextBlock FontSize="16" FontWeight="SemiBold"><Run Text="{Binding Number}" /><Run Text=" - " /><Run Text="{Binding Name}" /></TextBlock><TextBlock Text="{Binding OccupancyClassification}" Style="{StaticResource MutedText}" /><TextBlock Style="{StaticResource MutedText}"><Run Text="Area " /><Run Text="{Binding AreaSquareFeet, StringFormat=N0}" /><Run Text=" sq ft | Ceiling " /><Run Text="{Binding CeilingHeightFeet, StringFormat=N1}" /><Run Text=" ft" /></TextBlock></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Hazard + Ceiling" Width="1.7*"><DataGridTemplateColumn.CellTemplate><DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}"><StackPanel Margin="8,6"><TextBlock Text="{Binding CeilingClassification}" FontWeight="SemiBold" /><TextBlock Style="{StaticResource MutedText}"><Run Text="Suggested: " /><Run Text="{Binding SuggestedHazard}" /></TextBlock>                        <ComboBox Width="150" Margin="0,6,0,0" ItemsSource="{Binding DataContext.HazardOptions, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedItem="{Binding UserOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Recommended Sprinkler" Width="2.2*"><DataGridTemplateColumn.CellTemplate><DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}"><StackPanel Margin="8,6"><TextBlock Text="{Binding AutoSelectedSprinklerName}" FontWeight="SemiBold" TextWrapping="Wrap" /><ComboBox DisplayMemberPath="DisplayName" ItemsSource="{Binding CompatibleSprinklerOptions}" SelectedItem="{Binding SelectedRoomSprinklerFamily, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /><TextBlock Style="{StaticResource MutedText}"><Run Text="{Binding SprinklerSelectionStatus}" /><Run Text=" | " /><Run Text="{Binding CompatibleSprinklerCount}" /><Run Text=" compatible" /></TextBlock></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Layout Status" Width="1.5*"><DataGridTemplateColumn.CellTemplate><DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}"><StackPanel Margin="8,6"><DockPanel><TextBlock Text="{Binding LayoutStatus}" FontWeight="SemiBold" DockPanel.Dock="Left" /><CheckBox Content="Exception" IsChecked="{Binding RequiresExceptionReview, Mode=OneWay}" IsHitTestVisible="False" Focusable="False" HorizontalAlignment="Right" /></DockPanel><ProgressBar Value="{Binding Room.LayoutConfidenceScore, Mode=OneWay}" Maximum="1" Height="8" Margin="0,8,0,4" /><TextBlock Style="{StaticResource MutedText}"><Run Text="{Binding Room.LayoutConfidenceScore, StringFormat=P0}" /><Run Text=" | " /><Run Text="{Binding ProposedSprinklerCount}" /><Run Text=" heads | " /><Run Text="{Binding PreviewMarkers}" /></TextBlock></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="3  Exceptions + Overrides"><Grid Margin="0,14,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Border Style="{StaticResource CardBorder}" Margin="0,0,0,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Exception workflow" Style="{StaticResource SectionTitle}" /><TextBlock Text="Focus on rooms that require designer action or manufacturer overrides." Style="{StaticResource MutedText}" /></StackPanel><CheckBox Grid.Column="1" Content="Review only exceptions" IsChecked="{Binding ReviewOnlyExceptions}" VerticalAlignment="Center" Margin="18,0,0,0" /><Button Grid.Column="2" Content="Reset Sprinklers" Command="{Binding ResetSprinklerOverridesCommand}" VerticalAlignment="Center" Margin="12,0,0,0" /></Grid></Border><DataGrid Grid.Row="1" ItemsSource="{Binding RoomsView}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" AlternatingRowBackground="#F8FAFC" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" RowHeaderWidth="0" RowHeight="84" HeadersVisibility="Column"><DataGrid.Columns><DataGridTextColumn Header="Room" Binding="{Binding Number}" Width="90" IsReadOnly="True" /><DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.3*" IsReadOnly="True" /><DataGridTextColumn Header="Issue / Exception Reason" Binding="{Binding ExceptionReason}" Width="2*" IsReadOnly="True" /><DataGridTemplateColumn Header="Compatible Override" Width="2*"><DataGridTemplateColumn.CellTemplate><DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}"><ComboBox DisplayMemberPath="DisplayName" ItemsSource="{Binding CompatibleSprinklerOptions}" SelectedItem="{Binding SelectedRoomSprinklerFamily, UpdateSourceTrigger=PropertyChanged}" Margin="6" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridTemplateColumn Header="Approved" Width="110"><DataGridTemplateColumn.CellTemplate><DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}"><CheckBox IsChecked="{Binding IsApproved, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn></DataGrid.Columns></DataGrid></Grid></TabItem>
            <TabItem Header="4  Summary + Save"><Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Border Style="{StaticResource CardBorder}"><StackPanel><TextBlock Text="Ready to save" Style="{StaticResource SectionTitle}" /><TextBlock Text="Save approved hazard classifications and generated sprinkler layout data for the next placement workflow." Style="{StaticResource MutedText}" /><Separator Margin="0,16,0,16" /><TextBlock Text="Before saving, review unresolved exceptions and room-specific manufacturer overrides." Style="{StaticResource MutedText}" /><TextBlock Text="{Binding ValidationMessage}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" Margin="0,14,0,0" /></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12"><StackPanel><TextBlock Text="Project snapshot" Style="{StaticResource SectionTitle}" /><TextBlock Style="{StaticResource MutedText}"><Run Text="Rooms: " /><Run Text="{Binding TotalRoomCount}" /></TextBlock><TextBlock Style="{StaticResource MutedText}"><Run Text="Exceptions: " /><Run Text="{Binding ExceptionRoomCount}" /></TextBlock><TextBlock Style="{StaticResource MutedText}"><Run Text="Auto-solved: " /><Run Text="{Binding AutoSolvedRoomCount}" /></TextBlock><TextBlock Style="{StaticResource MutedText}"><Run Text="Average confidence: " /><Run Text="{Binding AverageConfidenceText}" /></TextBlock></StackPanel></Border></Grid></TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,0,0,4" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Find rooms" Style="{StaticResource SectionTitle}" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search room number, name, occupancy, or ceiling type"
                                 Margin="0,0,10,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding HazardFilters}"
                                  SelectedItem="{Binding HazardFilter}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Project sprinkler standard" Style="{StaticResource SectionTitle}" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Manufacturer" Style="{StaticResource LabelText}" />
                            <ComboBox ItemsSource="{Binding ManufacturerOptions}"
                                      SelectedItem="{Binding SelectedManufacturer}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Category" Style="{StaticResource LabelText}" />
                            <ComboBox ItemsSource="{Binding CategoryOptions}"
                                      SelectedItem="{Binding SelectedCategory}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Orientation" Style="{StaticResource LabelText}" />
                            <ComboBox ItemsSource="{Binding OrientationOptions}"
                                      SelectedItem="{Binding SelectedOrientation}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="K-factor" Style="{StaticResource LabelText}" />
                            <ComboBox ItemsSource="{Binding KFactorOptions}"
                                      SelectedItem="{Binding SelectedKFactor}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Search model / SIN" Style="{StaticResource LabelText}" />
                            <TextBox Text="{Binding SprinklerSearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Model / SIN" Style="{StaticResource LabelText}" />
                            <ComboBox DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding SprinklerFamilies}"
                                      SelectedItem="{Binding SelectedSprinklerFamily}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3"
                            Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Listing summary" Style="{StaticResource LabelText}" />
                            <TextBlock Text="{Binding SelectedFamilyListingSummary}"
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Border>
                    <TextBlock Grid.Row="4"
                               Text="SprinkSnap applies code/listing compatibility first, then project standard preference, then alternates for designer override."
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                    <CheckBox Grid.Row="5"
                              Content="Allow compatible alternate manufacturers for room overrides"
                              IsChecked="{Binding AllowAlternateManufacturers}"
                              Margin="0,8,0,0"
                              ToolTip="When checked, each room can be overridden to another manufacturer if the selected head is compatible with the room hazard, ceiling, and geometry." />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Water supply / demand" Style="{StaticResource SectionTitle}" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Static PSI" Style="{StaticResource LabelText}" />
                            <TextBox Text="{Binding StaticPressurePsi, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Residual PSI" Style="{StaticResource LabelText}" />
                            <TextBox Text="{Binding ResidualPressurePsi, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Flow GPM" Style="{StaticResource LabelText}" />
                            <TextBox Text="{Binding FlowGpm, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Visibility="Collapsed"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="0">
            <DataGrid ItemsSource="{Binding RoomsView}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeColumns="True"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F8FAFC"
                      Background="White"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      RowHeight="92"
                      HeadersVisibility="Column"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                        <Border Background="#F8FAFC"
                                BorderBrush="#E5E7EB"
                                BorderThickness="0,1,0,0"
                                Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ceiling intelligence" Style="{StaticResource LabelText}" />
                                    <TextBlock Text="{Binding CeilingIntelligenceSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                    <TextBlock Text="Exception / review reason" Style="{StaticResource LabelText}" />
                                    <TextBlock Text="{Binding ExceptionReason}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="18,0,0,0">
                                    <TextBlock Text="Hazard suggestion basis" Style="{StaticResource LabelText}" />
                                    <TextBlock Text="{Binding SuggestionReason}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="18,64,0,0">
                                    <TextBlock Text="Compatible alternates" Style="{StaticResource LabelText}" />
                                    <TextBlock Text="{Binding AlternateSprinklerSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Room" Width="2.2*" SortMemberPath="Number">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                                <StackPanel Margin="8,6">
                                    <TextBlock FontSize="16" FontWeight="SemiBold">
                                        <Run Text="{Binding Number}" />
                                        <Run Text=" - " />
                                        <Run Text="{Binding Name}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding OccupancyClassification}" Style="{StaticResource MutedText}" />
                                    <TextBlock Style="{StaticResource MutedText}">
                                        <Run Text="Area " />
                                        <Run Text="{Binding AreaSquareFeet, StringFormat=N0}" />
                                        <Run Text=" sq ft | Height " />
                                        <Run Text="{Binding HeightFeet, StringFormat=N1}" />
                                        <Run Text=" ft | Ceiling " />
                                        <Run Text="{Binding CeilingHeightFeet, StringFormat=N1}" />
                                        <Run Text=" ft" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Ceiling + Geometry" Width="1.6*" SortMemberPath="CeilingClassification">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                                <StackPanel Margin="8,6">
                                    <TextBlock Text="{Binding CeilingClassification}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CeilingType}" Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding CeilingIntelligenceSummary}" Style="{StaticResource MutedText}" MaxHeight="36" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Hazard Review" Width="1.55*" SortMemberPath="UserOverride">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                                <Grid Margin="8,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource MutedText}">
                                        <Run Text="Suggested: " />
                                        <Run Text="{Binding SuggestedHazard}" />
                                    </TextBlock>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                        <ComboBox Width="150"
                                                  ItemsSource="{Binding DataContext.HazardOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding UserOverride, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Content="Approved"
                                                  IsChecked="{Binding IsApproved, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="10,0,0,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Auto Layout" Width="1.7*" SortMemberPath="LayoutStatus">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                                <StackPanel Margin="8,6">
                                    <DockPanel>
                                        <TextBlock Text="{Binding LayoutStatus}" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                        <CheckBox Content="Exception"
                                                  IsChecked="{Binding RequiresExceptionReview, Mode=OneWay}"
                                                  IsHitTestVisible="False"
                                                  Focusable="False"
                                                  HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding AutoSelectedSprinklerName}"
                                               FontWeight="SemiBold"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                    <ComboBox DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding CompatibleSprinklerOptions}"
                                              SelectedItem="{Binding SelectedRoomSprinklerFamily, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,6,0,0"
                                              ToolTip="Override this room with another compatible manufacturer/model" />
                                    <TextBlock Style="{StaticResource MutedText}">
                                        <Run Text="{Binding SprinklerSelectionStatus}" />
                                        <Run Text=" | " />
                                        <Run Text="{Binding CompatibleSprinklerCount}" />
                                        <Run Text=" compatible head(s)" />
                                    </TextBlock>
                                    <ProgressBar Value="{Binding Room.LayoutConfidenceScore, Mode=OneWay}"
                                                 Maximum="1"
                                                 Height="8"
                                                 Margin="0,8,0,4" />
                                    <TextBlock Style="{StaticResource MutedText}">
                                        <Run Text="{Binding Room.LayoutConfidenceScore, StringFormat=P0}" />
                                        <Run Text=" confidence | " />
                                        <Run Text="{Binding ProposedSprinklerCount}" />
                                        <Run Text=" heads | " />
                                        <Run Text="{Binding PreviewMarkers}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="4"
              Margin="0,14,0,0"
              Visibility="{Binding ShowDialogActions, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{StaticResource WarningBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Accept Suggestions"
                        MinWidth="150"
                        Command="{Binding AcceptAllSuggestionsCommand}" />
                <ComboBox Width="130"
                          Margin="8,0,0,0"
                          ItemsSource="{Binding HazardOptions}"
                          SelectedItem="{Binding SelectedBatchHazard}" />
                <Button Content="Batch Apply"
                        Command="{Binding ApplyCommand}" />
                <Button Content="Override"
                        Command="{Binding OverrideCommand}" />
                <Button Content="Reset Sprinklers"
                        MinWidth="140"
                        Command="{Binding ResetSprinklerOverridesCommand}" />
                <Button Content="Save"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" />
                <Button Content="Cancel"
                        IsCancel="True"
                        Command="{Binding CancelCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
