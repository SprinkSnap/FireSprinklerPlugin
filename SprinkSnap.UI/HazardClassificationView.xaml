<Window x:Class="FireSprinklerPlugin.SprinkSnap.UI.HazardClassificationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI"
        Title="SprinkSnap Hazard Classification Review"
        Height="780"
        Width="1220"
        MinHeight="540"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style x:Key="RightAlignedCellText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="SprinkSnap NFPA 13 Hazard Classification Review"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Text="Suggested classifications are rule-based only. Designer approval is mandatory before any sprinkler placement workflow can use this room data."
                       Foreground="#4B5563"
                       Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Search by room number, name, occupancy, or ceiling type" />

                <TextBlock Grid.Column="1"
                           Text="Filter:"
                           VerticalAlignment="Center"
                           Margin="14,0,6,0" />
                <ComboBox Grid.Column="2"
                          Height="32"
                          ItemsSource="{Binding HazardFilters}"
                          SelectedItem="{Binding HazardFilter}" />

                <TextBlock Grid.Column="3"
                           Text="Batch:"
                           VerticalAlignment="Center"
                           Margin="14,0,6,0" />
                <ComboBox Grid.Column="4"
                          Height="32"
                          ItemsSource="{Binding HazardOptions}"
                          SelectedItem="{Binding SelectedBatchHazard}" />

                <Button Grid.Column="5"
                        Content="Apply"
                        Command="{Binding ApplyCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Static Pressure PSI:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,6,0" />
                <TextBox Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Text="{Binding StaticPressurePsi, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Available static pressure from flow test or water supply data" />

                <TextBlock Grid.Column="2"
                           Text="Residual Pressure PSI:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="18,0,6,0" />
                <TextBox Grid.Column="3"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Text="{Binding ResidualPressurePsi, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Residual pressure at the measured test flow" />

                <TextBlock Grid.Column="4"
                           Text="Flow GPM:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="18,0,6,0" />
                <TextBox Grid.Column="5"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Text="{Binding FlowGpm, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Measured or available flow in gallons per minute" />

                <TextBlock Grid.Column="6"
                           Text="Water demand values are captured for future hydraulic calculation workflows."
                           Foreground="#4B5563"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding RoomsView}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9FAFB"
                  Background="White"
                  BorderBrush="#D1D5DB"
                  BorderThickness="1"
                  RowHeaderWidth="0"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Room Number"
                                    Binding="{Binding Number}"
                                    IsReadOnly="True"
                                    SortMemberPath="Number"
                                    Width="115" />
                <DataGridTextColumn Header="Room Name"
                                    Binding="{Binding Name}"
                                    IsReadOnly="True"
                                    SortMemberPath="Name"
                                    Width="1.4*" />
                <DataGridTextColumn Header="Area (sq ft)"
                                    Binding="{Binding AreaSquareFeet, StringFormat=N2}"
                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                    IsReadOnly="True"
                                    SortMemberPath="AreaSquareFeet"
                                    Width="115" />
                <DataGridTextColumn Header="Height (ft)"
                                    Binding="{Binding HeightFeet, StringFormat=N2}"
                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                    IsReadOnly="True"
                                    SortMemberPath="HeightFeet"
                                    Width="100" />
                <DataGridTextColumn Header="Ceiling Height (ft)"
                                    Binding="{Binding CeilingHeightFeet, StringFormat=N2}"
                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                    IsReadOnly="True"
                                    SortMemberPath="CeilingHeightFeet"
                                    Width="140" />
                <DataGridTextColumn Header="Ceiling Type"
                                    Binding="{Binding CeilingType}"
                                    IsReadOnly="True"
                                    SortMemberPath="CeilingType"
                                    Width="140" />
                <DataGridTextColumn Header="Occupancy"
                                    Binding="{Binding OccupancyClassification}"
                                    IsReadOnly="True"
                                    SortMemberPath="OccupancyClassification"
                                    Width="140" />
                <DataGridTextColumn Header="Suggested Hazard"
                                    Binding="{Binding SuggestedHazard}"
                                    IsReadOnly="True"
                                    SortMemberPath="SuggestedHazard"
                                    Width="135" />
                <DataGridTemplateColumn Header="User Override"
                                        SortMemberPath="UserOverride"
                                        Width="145">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                            <ComboBox ItemsSource="{Binding DataContext.HazardOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding UserOverride, UpdateSourceTrigger=PropertyChanged}"
                                      MinWidth="120" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridCheckBoxColumn Header="Approved"
                                        Binding="{Binding IsApproved, UpdateSourceTrigger=PropertyChanged}"
                                        SortMemberPath="IsApproved"
                                        Width="90" />
                <DataGridTextColumn Header="Suggestion Basis"
                                    Binding="{Binding SuggestionReason}"
                                    IsReadOnly="True"
                                    Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4"
                   Text="{Binding ValidationMessage}"
                   Foreground="#B45309"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Accept All Suggestions"
                    MinWidth="170"
                    Command="{Binding AcceptAllSuggestionsCommand}" />
            <Button Content="Apply"
                    Command="{Binding ApplyCommand}" />
            <Button Content="Save"
                    IsDefault="True"
                    Background="#2563EB"
                    Foreground="White"
                    Command="{Binding SaveCommand}" />
            <Button Content="Cancel"
                    IsCancel="True"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>

