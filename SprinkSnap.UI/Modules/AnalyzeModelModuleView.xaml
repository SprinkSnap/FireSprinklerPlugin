<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.AnalyzeModelModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4">
            <TextBlock Text="Analyze Model" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,8" />
            <Border Background="#FEF3C7"
                    BorderBrush="#F59E0B"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Visibility="{Binding IsModelStale, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ModelChangeSummary}" TextWrapping="Wrap" Foreground="#92400E" />
            </Border>

            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Rooms" Foreground="#6B7280" />
                        <TextBlock Text="{Binding RoomCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Sloped ceilings" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SlopedCeilingCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Missing ceilings" Foreground="#6B7280" />
                        <TextBlock Text="{Binding MissingCeilingCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Obstructions" Foreground="#6B7280" />
                        <TextBlock Text="{Binding ObstructionZoneCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Existing sprinklers" Foreground="#6B7280" />
                        <TextBlock Text="{Binding ExistingSprinklerCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Linked models" Foreground="#6B7280" />
                        <TextBlock Text="{Binding LinkedModelCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Run Analysis" Command="{Binding RunAnalysisCommand}" Padding="14,8" Margin="0,0,8,0" />
                <Button Content="Export JSON" Command="{Binding ExportJsonCommand}" Padding="14,8" />
            </StackPanel>

            <TextBlock Text="Extracted rooms" FontWeight="SemiBold" Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding Rooms}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      MinHeight="220"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Number" Binding="{Binding Number}" Width="80" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.4*" />
                    <DataGridTextColumn Header="Occupancy" Binding="{Binding OccupancyClassification}" Width="1.2*" />
                    <DataGridTextColumn Header="Ceiling" Binding="{Binding CeilingType}" Width="1.2*" />
                    <DataGridTextColumn Header="Area (sq ft)" Binding="{Binding AreaSquareFeet, StringFormat=N0}" Width="110" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
