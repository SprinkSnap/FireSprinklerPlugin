<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.SprinklerReviewModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI"
             Background="#EEF2F7">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Sprinkler Review" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Set project manufacturer standards and approve compatible listed heads per room."
                           Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Manufacturer" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding ManufacturerOptions}" SelectedItem="{Binding SelectedManufacturer}" Height="34" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Category" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding CategoryOptions}" SelectedItem="{Binding SelectedCategory}" Height="34" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Orientation" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding OrientationOptions}" SelectedItem="{Binding SelectedOrientation}" Height="34" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="K-factor" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding KFactorOptions}" SelectedItem="{Binding SelectedKFactor}" Height="34" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Project model / SIN" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" />
                    <ComboBox DisplayMemberPath="DisplayName" ItemsSource="{Binding SprinklerFamilies}" SelectedItem="{Binding SelectedSprinklerFamily}" Height="34" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Margin="12">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Reset Overrides" Command="{Binding ResetSprinklerOverridesCommand}" Padding="12,8" Margin="0,0,8,0" />
                        <Button Content="Apply Project Standard" Command="{Binding SaveCommand}" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Padding="12,8" />
                    </StackPanel>
                    <CheckBox Content="Allow compatible alternate manufacturers for room overrides"
                              IsChecked="{Binding AllowAlternateManufacturers}"
                              VerticalAlignment="Center" />
                </DockPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding RoomsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="84"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F8FAFC"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Room" Binding="{Binding Number}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Hazard" Binding="{Binding UserOverride}" Width="1*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Recommended" Binding="{Binding AutoSelectedSprinklerName}" Width="1.4*" IsReadOnly="True" />
                        <DataGridTextColumn Header="High Ceiling" Binding="{Binding HighCeilingSprinklerStatus}" Width="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="NFPA 19.2.3.2.5.1" Binding="{Binding HighCeilingSprinklerSummary}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Mapping" Binding="{Binding RevitFamilyMappingStatus}" Width="120" IsReadOnly="True" />
                        <DataGridTemplateColumn Header="Room Override" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                                    <ComboBox DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding CompatibleSprinklerOptions}"
                                              SelectedItem="{Binding SelectedRoomSprinklerFamily, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="6" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
