<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.GenerateDesignModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="760">
            <TextBlock Text="Generate Design" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,16" />

            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Rooms" Foreground="#6B7280" />
                        <TextBlock Text="{Binding RoomCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Approved hazards" Foreground="#6B7280" />
                        <TextBlock Text="{Binding ApprovedRoomCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Water supply ready" Foreground="#6B7280" />
                        <TextBlock Text="{Binding HasWaterSupply}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Button Content="Generate Sprinkler Design" Command="{Binding GenerateCommand}" Padding="14,8" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
