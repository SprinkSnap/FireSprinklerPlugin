<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.SettingsModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:modules="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI.Modules">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="980">
            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,16" />

            <TextBlock Text="Manufacturer sprinkler catalog" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Text="Load listed sprinkler families from sprinkler_catalog.json. The default catalog ships with SprinkSnap; point to a custom JSON file to extend or replace manufacturers."
                       TextWrapping="Wrap"
                       Foreground="#4B5563"
                       Margin="0,0,0,10" />

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding CatalogPath, UpdateSourceTrigger=PropertyChanged}"
                         Height="34"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{Binding BrowseCatalogCommand}"
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Grid.Column="2"
                        Content="Reload"
                        Command="{Binding ReloadCatalogCommand}"
                        Padding="12,6" />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Foreground="#6B7280" Margin="0,0,16,0">
                    <Run Text="Source: " /><Run Text="{Binding CatalogSourceKind}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Foreground="#6B7280" Margin="0,0,16,0">
                    <Run Text="Library: " /><Run Text="{Binding CatalogLibraryName}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Foreground="#6B7280">
                    <Run Text="Families: " /><Run Text="{Binding CatalogFamilyCount}" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>

            <TextBlock Text="Default pipe diameters" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,6" />
            <TextBlock Text="Starting branch and main diameters used for schematic routing, hydraulics, sizing, and takeoff before velocity upsizing."
                       TextWrapping="Wrap"
                       Foreground="#4B5563"
                       Margin="0,0,0,10" />

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Branch diameter (in)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding DefaultBranchDiameterInches, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="Main diameter (in)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding DefaultMainDiameterInches, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Velocity limits" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Text="Maximum allowable pipe velocities used for upsizing, violation checks, and hydraulic warnings."
                       TextWrapping="Wrap"
                       Foreground="#4B5563"
                       Margin="0,0,0,10" />

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Branch limit (ft/s)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding BranchVelocityLimitFeetPerSecond, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="Main/riser limit (ft/s)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding MainVelocityLimitFeetPerSecond, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Default manufacturer" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding ManufacturerOptions}"
                      SelectedItem="{Binding DefaultManufacturer}"
                      Height="34"
                      Margin="0,0,0,12" />

            <CheckBox Content="Allow compatible alternate manufacturers for room overrides"
                      IsChecked="{Binding AllowAlternateManufacturers}"
                      Margin="0,0,0,12" />

            <TextBlock Text="AI service endpoint (future)" Margin="0,0,0,4" />
            <TextBox Text="{Binding AiServiceEndpoint, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,20" />

            <TextBlock Text="Revit family mapping" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Text="Map SprinkSnap catalog families to any sprinkler type loaded in the Revit project. All OST_Sprinklers family types are scanned — not only catalog matches."
                       TextWrapping="Wrap"
                       Foreground="#4B5563"
                       Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Run Text="Loaded Revit types: " /><Run Text="{Binding LoadedRevitSymbolCount}" FontWeight="SemiBold" />
                </TextBlock>
                <Button Content="Refresh Loaded Types"
                        Command="{Binding RefreshLoadedSymbolsCommand}"
                        Padding="12,6" />
            </StackPanel>

            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,16">
                <DataGrid ItemsSource="{Binding FamilyMappingRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="72"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F8FAFC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="110" IsReadOnly="True" />
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="110" IsReadOnly="True" />
                        <DataGridTextColumn Header="Catalog Family" Binding="{Binding DisplayName}" Width="1.6*" IsReadOnly="True" />
                        <DataGridTemplateColumn Header="Loaded Revit Type" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type modules:FamilyMappingRowViewModel}">
                                    <ComboBox DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding LoadedRevitSymbols}"
                                              SelectedItem="{Binding SelectedRevitSymbol, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="6" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Status" Binding="{Binding MappingStatus}" Width="120" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <TextBlock Text="Linked model clash detection" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Text="Choose which loaded Revit links SprinkSnap scans for duct, pipe, beam, and fixture conflicts."
                       TextWrapping="Wrap"
                       Foreground="#4B5563"
                       Margin="0,0,0,10" />

            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,16">
                <DataGrid ItemsSource="{Binding LinkedModelScanOptions}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="56"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F8FAFC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Link Name" Binding="{Binding LinkName}" Width="1.4*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Document" Binding="{Binding DocumentTitle}" Width="1.4*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Status" Binding="{Binding LoadStatus}" Width="100" IsReadOnly="True" />
                        <DataGridCheckBoxColumn Header="Scan for clashes" Binding="{Binding IncludeInClashScan}" Width="130" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Button Content="Save Settings" Command="{Binding SaveCommand}" Padding="14,8" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
