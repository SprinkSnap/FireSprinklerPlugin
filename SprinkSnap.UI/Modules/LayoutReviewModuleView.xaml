<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.LayoutReviewModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI"
             Background="#EEF2F7">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Validate" Command="{Binding ValidateCommand}" Padding="12,8" Margin="0,0,8,0" />
                    <Button Content="Auto-Layout All" Command="{Binding AutoLayoutCommand}" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Padding="12,8" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Generate Design" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Generate NFPA 13 compliant sprinkler layouts with schematic branch lines, cross mains, and risers. Confident rooms auto-solve; exceptions stay visible."
                               Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Schematic pipe routing" FontWeight="SemiBold" />
                <TextBlock Text="{Binding PipeRoutingSummary}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding RoomsView}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  RowHeight="96"
                  RowHeaderWidth="0"
                  Background="White"
                  BorderBrush="#D1D5DB"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8FAFC">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Room" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                            <StackPanel Margin="8,6">
                                <TextBlock FontWeight="SemiBold"><Run Text="{Binding Number}" /><Run Text=" - " /><Run Text="{Binding Name}" /></TextBlock>
                                <TextBlock Foreground="#6B7280"><Run Text="Head: " /><Run Text="{Binding AutoSelectedSprinklerName}" /></TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Layout Status" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                            <StackPanel Margin="8,6">
                                <TextBlock Text="{Binding LayoutStatus}" FontWeight="SemiBold" />
                                <ProgressBar Value="{Binding Room.LayoutConfidenceScore, Mode=OneWay}" Maximum="1" Height="8" Margin="0,8,0,4" />
                                <TextBlock Foreground="#6B7280">
                                    <Run Text="{Binding ProposedSprinklerCount}" /><Run Text=" heads | " /><Run Text="{Binding PreviewMarkers}" />
                                </TextBlock>
                                <TextBlock Foreground="#6B7280" Margin="0,4,0,0">
                                    <Run Text="{Binding PipeSegmentCount}" /><Run Text=" pipe segments | " /><Run Text="{Binding PipeLengthFeet, StringFormat=N0}" /><Run Text=" ft" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Exception" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type ui:RoomHazardReviewItem}">
                            <StackPanel Margin="8,6">
                                <CheckBox Content="Needs review" IsChecked="{Binding RequiresExceptionReview, Mode=OneWay}" IsEnabled="False" />
                                <TextBlock Text="{Binding ExceptionReason}" Foreground="#B45309" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
