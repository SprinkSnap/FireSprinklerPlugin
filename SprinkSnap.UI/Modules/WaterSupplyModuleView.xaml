<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.WaterSupplyModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="720">
            <TextBlock Text="Water Supply" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="Enter the current hydrant flow test used for this design. Fields start empty until you type values or import a CSV, then click Validate Supply."
                       TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,8" />
            <TextBlock Text="{Binding NfpaReferenceSummary}" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,0,0,12" />

            <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding RequiresValidation, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding RequiresValidationMessage}" TextWrapping="Wrap" Foreground="#92400E" />
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Import CSV"
                        Command="{Binding ImportCsvCommand}"
                        Padding="14,8"
                        Margin="0,0,8,0" />
                <Button Content="Validate Supply"
                        Command="{Binding ValidateCommand}"
                        Padding="14,8" />
            </StackPanel>

            <TextBlock Text="{Binding ImportedSourceSummary}"
                       Foreground="#6B7280"
                       Margin="0,0,0,16" />

            <TextBlock Text="Static pressure (PSI)" Margin="0,0,0,4" />
            <TextBox Text="{Binding StaticPressurePsi, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,12" Tag="Required" />

            <TextBlock Text="Residual pressure (PSI)" Margin="0,0,0,4" />
            <TextBox Text="{Binding ResidualPressurePsi, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,12" Tag="Required" />

            <TextBlock Text="Flow at residual (GPM)" Margin="0,0,0,4" />
            <TextBox Text="{Binding FlowGpm, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,12" Tag="Required" />

            <TextBlock Text="Hydrant test date (required)" Margin="0,0,0,4" />
            <TextBox Text="{Binding HydrantTestDate, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,16" Tag="Required" />

            <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Hydraulic supply anchor" Foreground="#6B7280" />
                    <TextBlock Text="{Binding SupplyAnchorSummary}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="Pick or clear the supply anchor in the Hydraulics module. Validation and hydraulics both use this anchor when set."
                               TextWrapping="Wrap" Foreground="#6B7280" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                <TextBlock Text="{Binding ValidationSummary}" TextWrapping="Wrap" Foreground="#1E3A8A" />
            </Border>

            <controls:WaterSupplyCurveChart SupplyCurve="{Binding SupplyCurve}"
                                          DemandCurve="{Binding DemandCurve}"
                                          DemandFlowGpm="{Binding DemandFlowGpm}"
                                          DemandPressurePsi="{Binding DemandPressurePsi}"
                                          Visibility="{Binding ShowSupplyChart, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Margin="0,0,0,8" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
