<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.HydraulicsModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="820">
            <TextBlock Text="Hydraulics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="Calculate NFPA 13 remote-area demand using a segment-graph critical path from placed Revit pipe topology when available, shared project trunk mains, per-head Q = K√P, and Hazen-Williams friction per pipe segment. In Revit, placed pipe lengths are re-measured from current geometry before each run."
                       TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,8" />
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,16" />

            <Border Background="#FEF3C7"
                    BorderBrush="#F59E0B"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,16"
                    Visibility="{Binding IsDownstreamStaleActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding DownstreamStaleBannerTitle}" FontWeight="SemiBold" Foreground="#92400E" />
                    <TextBlock Text="{Binding DownstreamStaleBannerMessage}" TextWrapping="Wrap" Foreground="#92400E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Hydraulic supply anchor" Foreground="#6B7280" />
                    <TextBlock Text="{Binding SupplyAnchorSummary}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Pick Supply in Revit" Command="{Binding PickSupplyAnchorCommand}" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="Clear Anchor" Command="{Binding ClearSupplyAnchorCommand}" Padding="12,6" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Content="Run Hydraulics" Command="{Binding CalculateCommand}" Padding="14,8" HorizontalAlignment="Left" Margin="0,0,0,16" />

            <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Controlling hazard" Foreground="#6B7280" />
                    <TextBlock Text="{Binding ControllingHazard}" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding NfpaReference}" Foreground="#6B7280" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <UniformGrid Columns="3" Margin="0,0,0,8">
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Design density" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding DesignDensity, StringFormat=N2}" /><Run Text=" gpm/sq ft" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Remote area" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding RemoteAreaSquareFeet, StringFormat=N0}" /><Run Text=" sq ft" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Hose stream" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding HoseStreamAllowanceGpm, StringFormat=N0}" /><Run Text=" GPM" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Sprinkler demand" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SprinklerDemandFlowGpm, StringFormat=N1}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Total flow" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TotalFlowGpm, StringFormat=N1}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="System demand" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SystemDemandPsi, StringFormat=N1}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Operating sprinklers" Foreground="#6B7280" />
                        <TextBlock Text="{Binding OperatingSprinklerCount}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Flow per head" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding FlowPerOperatingSprinklerGpm, StringFormat=N1}" /><Run Text=" GPM" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Branch length" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding BranchLengthFeet, StringFormat=N0}" /><Run Text=" ft" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Main length" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding MainLengthFeet, StringFormat=N0}" /><Run Text=" ft" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Pipe length source" Foreground="#6B7280" />
                        <TextBlock Text="{Binding PipeLengthDataSource}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Max velocity" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding MaxCriticalPathVelocityFeetPerSecond, StringFormat=N1}" /><Run Text=" ft/s" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Velocity violations" Foreground="#6B7280" />
                        <TextBlock Text="{Binding CriticalPathVelocityViolationCount}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Diameter suggestions" Foreground="#6B7280" />
                        <TextBlock Text="{Binding CriticalPathDiameterSuggestionCount}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Applied sizing" Foreground="#6B7280" />
                        <TextBlock Text="{Binding AppliedPipeSizingSegmentCount}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Schematic writeback" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SchematicWritebackSegmentCount}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Revit sync" Foreground="#6B7280" />
                        <TextBlock Text="{Binding RevitPipeDiameterSyncCount}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Fitting sync" Foreground="#6B7280" />
                        <TextBlock Text="{Binding RevitFittingDiameterSyncCount}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Post-sync re-solve" Foreground="#6B7280" />
                        <TextBlock Text="{Binding UsesPostSyncHydraulicReSolve}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Fitting friction" Foreground="#6B7280" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding FittingFrictionPsi, StringFormat=N1}" /><Run Text=" PSI" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Segment graph" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SegmentGraphHydraulicsStatus}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Remote area selection" Foreground="#6B7280" />
                        <TextBlock Text="{Binding RemoteAreaSelectionStatus}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Remote head" Foreground="#6B7280" />
                        <TextBlock Text="{Binding RemoteSprinklerLabel}" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <controls:WaterSupplyCurveChart SupplyCurve="{Binding SupplyCurve}"
                                          DemandFlowGpm="{Binding DemandFlowGpm}"
                                          DemandPressurePsi="{Binding DemandPressurePsi}"
                                          Visibility="{Binding ShowSupplyChart, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Margin="0,0,0,16" />

            <UniformGrid Columns="2" Margin="0,0,0,16">
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Available pressure (PSI)" Foreground="#6B7280" />
                        <TextBlock Text="{Binding AvailablePressurePsi, StringFormat=N1}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Safety margin (PSI)" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SafetyMarginPsi, StringFormat=N1}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Critical path" FontWeight="SemiBold" Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding CriticalPath}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      MinHeight="140"
                      Margin="0,0,0,16"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Node" Binding="{Binding NodeId}" Width="2*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding SegmentType}" Width="90" />
                    <DataGridTextColumn Header="Length (ft)" Binding="{Binding LengthFeet, StringFormat=N0}" Width="90" />
                    <DataGridTextColumn Header="Diameter (in)" Binding="{Binding DiameterInches, StringFormat=N2}" Width="100" />
                    <DataGridTextColumn Header="Suggested (in)" Binding="{Binding SuggestedDiameterInches, StringFormat=N2}" Width="100" />
                    <DataGridTextColumn Header="Pressure (PSI)" Binding="{Binding PressurePsi, StringFormat=N1}" Width="110" />
                    <DataGridTextColumn Header="Flow (GPM)" Binding="{Binding FlowGpm, StringFormat=N1}" Width="100" />
                    <DataGridTextColumn Header="Velocity (ft/s)" Binding="{Binding VelocityFeetPerSecond, StringFormat=N1}" Width="100" />
                    <DataGridTextColumn Header="Friction (PSI)" Binding="{Binding FrictionLossPsi, StringFormat=N1}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="Warnings" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding WarningSummary}" TextWrapping="Wrap" Foreground="#4B5563" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
