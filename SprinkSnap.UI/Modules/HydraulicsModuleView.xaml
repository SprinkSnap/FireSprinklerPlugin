<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.HydraulicsModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4" MaxWidth="760">
            <TextBlock Text="Hydraulics" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="Run deterministic Hazen-Williams demand calculations for the current project state."
                       TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,16" />

            <Button Content="Run Hydraulics" Command="{Binding CalculateCommand}" Padding="14,8" HorizontalAlignment="Left" Margin="0,0,0,16" />

            <UniformGrid Columns="2" Margin="0,0,0,16">
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Total flow (GPM)" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TotalFlowGpm, StringFormat=N1}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="System demand (PSI)" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SystemDemandPsi, StringFormat=N1}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Available pressure (PSI)" Foreground="#6B7280" />
                        <TextBlock Text="{Binding AvailablePressurePsi, StringFormat=N1}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Safety margin (PSI)" Foreground="#6B7280" />
                        <TextBlock Text="{Binding SafetyMarginPsi, StringFormat=N1}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Warnings" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding WarningSummary}" TextWrapping="Wrap" Foreground="#4B5563" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
