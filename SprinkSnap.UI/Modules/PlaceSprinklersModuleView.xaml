<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Modules.PlaceSprinklersModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#EEF2F7">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Validate"
                            Command="{Binding ValidateCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Place Schematic Pipes"
                            Command="{Binding PlacePipesInRevitCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Place in Revit"
                            Command="{Binding PlaceInRevitCommand}"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="14,8" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Place Sprinklers" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Validate family mapping and layout readiness, then create Revit sprinkler instances and schematic pipe segments from approved design."
                               Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,12">
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Candidates" Foreground="#6B7280" />
                    <TextBlock Text="{Binding TotalCandidates}" FontSize="26" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Ready" Foreground="#6B7280" />
                    <TextBlock Text="{Binding ReadyRoomCount}" FontSize="26" FontWeight="SemiBold" Foreground="#15803D" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Unmapped" Foreground="#6B7280" />
                    <TextBlock Text="{Binding UnmappedRoomCount}" FontSize="26" FontWeight="SemiBold" Foreground="#B45309" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Exceptions" Foreground="#6B7280" />
                    <TextBlock Text="{Binding ExceptionRoomCount}" FontSize="26" FontWeight="SemiBold" Foreground="#B91C1C" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Placed" Foreground="#6B7280" />
                    <TextBlock Text="{Binding PlacedCount}" FontSize="26" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Pipe segments" Foreground="#6B7280" />
                    <TextBlock Text="{Binding SchematicPipeSegmentCount}" FontSize="26" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="Pipes placed" Foreground="#6B7280" />
                    <TextBlock FontSize="26" FontWeight="SemiBold">
                        <Run Text="{Binding PlacedPipeSegmentCount}" /><Run Text=" / " /><Run Text="{Binding PlacedPipeLengthFeet, StringFormat=N0}" /><Run Text=" ft" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,8" />
                <CheckBox Content="Allow placement when some rooms have unmapped families (designer override)"
                          IsChecked="{Binding AllowUnmappedPlacement}"
                          Margin="0,0,0,8" />
                <CheckBox Content="Place schematic pipes after sprinklers"
                          IsChecked="{Binding PlaceSchematicPipesWithSprinklers}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Pre-flight validation" FontWeight="SemiBold" Margin="0,0,0,10" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PreflightRooms}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="80" />
                        <DataGridTextColumn Header="Name" Binding="{Binding RoomName}" Width="1.2*" />
                        <DataGridTextColumn Header="Sprinkler" Binding="{Binding SelectedSprinkler}" Width="1.4*" />
                        <DataGridTextColumn Header="Mapping" Binding="{Binding MappingStatus}" Width="120" />
                        <DataGridCheckBoxColumn Header="Ready" Binding="{Binding CanPlace}" Width="70" />
                        <DataGridTextColumn Header="Details" Binding="{Binding Message}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
