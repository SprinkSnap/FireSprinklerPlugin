<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Controls.WaterSupplyCurveChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Water supply curve (blue) with calculated demand point (red)"
                       Foreground="#6B7280"
                       Margin="0,0,0,8" />
            <Canvas x:Name="ChartCanvas" Grid.Row="1" MinHeight="220" />
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="X-axis: Flow (GPM)" Foreground="#6B7280" FontSize="11" />
                <TextBlock Grid.Column="1" Text="Y-axis: Pressure (PSI)" Foreground="#6B7280" FontSize="11" HorizontalAlignment="Right" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
