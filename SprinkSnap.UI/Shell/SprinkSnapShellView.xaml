<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Shell.SprinkSnapShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="980"
             MinHeight="640"
             Background="#EEF2F7">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="SPRINKSNAP AI"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding WorkflowSteps}" Margin="0,10,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E293B"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Step}" Foreground="White" FontSize="11" />
                                    <TextBlock Text="{Binding Status}" Foreground="#CBD5E1" FontSize="10" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Project Navigation" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigationItem}"
                             BorderThickness="0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="{Binding MainWorkspaceTitle}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding MainWorkspaceDescription}"
                               Foreground="#4B5563"
                               TextWrapping="Wrap"
                               Margin="0,8,0,20" />
                    <Border Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <TextBlock Text="Module workspace placeholder. Production views for analysis, hazard review, sprinkler review, water supply, layout generation, hydraulics, materials, and reports are hosted here."
                                   TextWrapping="Wrap"
                                   Foreground="#4B5563" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="Summary Panel" FontWeight="SemiBold" FontSize="16" />
                    <Separator Margin="0,10,0,10" />
                    <TextBlock Text="Compliance Status" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ComplianceStatus}" Foreground="#B45309" TextWrapping="Wrap" Margin="0,4,0,14" />
                    <TextBlock Text="Warnings" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding WarningSummary}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,4,0,14" />
                    <TextBlock Text="Progress" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ProgressSummary}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

