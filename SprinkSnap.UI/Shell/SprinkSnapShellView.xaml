<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Shell.SprinkSnapShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="980"
             MinHeight="640"
             Background="#EEF2F7">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="SPRINKSNAP AI"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="Ribbon Panels"
                           Foreground="#CBD5E1"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,12,0,6" />
                <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E293B"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="Ribbon panel" Foreground="#CBD5E1" FontSize="10" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Project Navigation" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigationItem}"
                             BorderThickness="0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="SprinkSnap AI Workflow Panels"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MainWorkspaceDescription}"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,16" />
                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ActionFeedback}"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding ModuleCapabilities}" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#1E40AF" TextWrapping="Wrap" Margin="0,0,0,4">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{Binding CurrentActionText}"
                                        Command="{Binding OpenModuleCommand}"
                                        CommandParameter="{Binding SelectedModulePanel}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Padding="14,8"
                                        Margin="18,0,0,0"
                                        VerticalAlignment="Top" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ModulePanels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="255"
                                            Height="158"
                                            Background="#F8FAFC"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16"
                                            Margin="0,0,14,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       FontSize="17"
                                                       Foreground="#0F172A" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       Foreground="#475569"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,10" />
                                            <Button Grid.Row="2"
                                                    Content="{Binding ActionText}"
                                                    Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#2563EB"
                                                    Foreground="White"
                                                    FontWeight="SemiBold"
                                                    Padding="10,6"
                                                    HorizontalAlignment="Left" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="Summary Panel" FontWeight="SemiBold" FontSize="16" />
                    <Separator Margin="0,10,0,10" />
                    <TextBlock Text="Compliance Status" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ComplianceStatus}" Foreground="#B45309" TextWrapping="Wrap" Margin="0,4,0,14" />
                    <TextBlock Text="Warnings" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding WarningSummary}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,4,0,14" />
                    <TextBlock Text="Progress" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ProgressSummary}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

