<UserControl x:Class="FireSprinklerPlugin.SprinkSnap.UI.Shell.SprinkSnapShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI.Shell"
             xmlns:branding="clr-namespace:FireSprinklerPlugin.SprinkSnap.UI.Branding"
             MinWidth="980"
             MinHeight="640"
             Background="#EEF2F7">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <Image Source="{x:Static branding:SprinkSnapBranding.LogoImage}"
                           Height="68"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           ToolTip="{x:Static branding:SprinkSnapBranding.ProductName}" />
                    <StackPanel DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasDocumentTitle, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Active Revit project"
                                   Foreground="#64748B"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding DocumentTitle, Mode=OneWay}"
                                   Foreground="#0F172A"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <TextBlock Text="Workflow Progress"
                           Foreground="#475569"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding WorkflowSteps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Summary, Mode=OneWay}"
                                               Foreground="#0F172A"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Workflow step"
                                               Foreground="#475569"
                                               FontSize="10" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="#FEF3C7"
                BorderBrush="#F59E0B"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,12"
                Visibility="{Binding IsReconciliationActive, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding ReconciliationBannerTitle}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#92400E"
                           Margin="0,0,0,6" />
                <TextBlock Text="{Binding ReconciliationBannerMessage}"
                           TextWrapping="Wrap"
                           Foreground="#92400E"
                           Margin="0,0,0,12" />
                <TextBlock Text="Reconciliation checklist"
                           FontWeight="SemiBold"
                           Foreground="#92400E"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ReconciliationSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                    BorderBrush="#FCD34D"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,0,8">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="Open"
                                            Command="{Binding DataContext.OpenReconciliationStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="10,4"
                                            Margin="12,0,0,0" />
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="#92400E">
                                            <Run Text="{Binding Title, Mode=OneWay}" />
                                            <Run Text=" — " />
                                            <Run Text="{Binding StatusText, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding Description, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#B45309"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,12,0">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom"
                            Content="All Modules"
                            Command="{Binding ShowDashboardCommand}"
                            Margin="0,10,0,0"
                            Padding="10,6" />
                    <StackPanel>
                        <TextBlock Text="Project Navigation" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <ListBox ItemsSource="{Binding ModulePanels}"
                                 SelectedItem="{Binding SelectedModulePanel, Mode=TwoWay}"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2,0,2">
                                        <DockPanel>
                                            <TextBlock Text="{Binding StatusLabel, Mode=OneWay}"
                                                       Foreground="{Binding StatusBrush, Mode=OneWay}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       DockPanel.Dock="Right" />
                                            <TextBlock Text="{Binding Title, Mode=OneWay}"
                                                       FontWeight="SemiBold" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding BlockReason, Mode=OneWay}"
                                                   Foreground="#B45309"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUnlocked}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,12">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="{Binding CurrentActionText}"
                                    Command="{Binding OpenModuleCommand}"
                                    CommandParameter="{Binding SelectedModulePanel}"
                                    Background="#2563EB"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Padding="14,8"
                                    Visibility="{Binding ShowModuleDashboard, Converter={StaticResource BoolToVis}}" />
                            <StackPanel>
                                <TextBlock Text="{Binding MainWorkspaceTitle}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MainWorkspaceDescription}"
                                           Foreground="#4B5563"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>

                    <ContentControl Grid.Row="1"
                                    Content="{Binding ActiveModuleContent}"
                                    Visibility="{Binding ShowModuleWorkspace, Converter={StaticResource BoolToVis}}" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding ShowModuleDashboard, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding ActionFeedback}"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding ModuleCapabilities}" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#1E40AF" TextWrapping="Wrap" Margin="0,0,0,4">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding ., Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding ModulePanels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="255"
                                                Height="180"
                                                Background="#F8FAFC"
                                                BorderBrush="#CBD5E1"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="16"
                                                Margin="0,0,14,14">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUnlocked}" Value="False">
                                                            <Setter Property="Opacity" Value="0.72" />
                                                            <Setter Property="Background" Value="#F1F5F9" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <DockPanel>
                                                    <TextBlock Text="{Binding StatusLabel, Mode=OneWay}"
                                                               Foreground="{Binding StatusBrush, Mode=OneWay}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               DockPanel.Dock="Right" />
                                                    <TextBlock Text="{Binding Title, Mode=OneWay}"
                                                               FontWeight="SemiBold"
                                                               FontSize="17"
                                                               Foreground="#0F172A" />
                                                </DockPanel>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding BlockReason, Mode=OneWay}"
                                                           Foreground="#B45309"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUnlocked}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Description, Mode=OneWay}"
                                                           Foreground="#475569"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,10" />
                                                <Button Grid.Row="3"
                                                        Content="{Binding ActionText, Mode=OneWay}"
                                                        Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding IsUnlocked}"
                                                        Background="#2563EB"
                                                        Foreground="White"
                                                        FontWeight="SemiBold"
                                                        Padding="10,6"
                                                        HorizontalAlignment="Left" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <TabControl>
                    <TabItem Header="Summary">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Compliance Status" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ComplianceStatus}" Foreground="#B45309" TextWrapping="Wrap" Margin="0,4,0,14" />
                            <TextBlock Text="Warnings" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding WarningSummary}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,4,0,14" />
                            <TextBlock Text="Progress" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ProgressSummary}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="AI Assistant">
                        <shell:AiAssistantPanelView DataContext="{Binding AiAssistant}" Margin="0,8,0,0" />
                    </TabItem>
                    <TabItem Header="NFPA 13 (2025)">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                            <StackPanel>
                                <Border Background="#EFF6FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,12">
                                    <StackPanel DataContext="{Binding HazardViewModel}">
                                        <TextBlock Text="Active Room Reference" FontWeight="SemiBold" Foreground="#1E3A8A" />
                                        <TextBlock Text="{Binding ActiveCodeReferenceSection, Mode=OneWay}" FontWeight="SemiBold" Margin="0,6,0,4" />
                                        <TextBlock Text="{Binding ActiveCodeReferenceSummary, Mode=OneWay}" TextWrapping="Wrap" Foreground="#1E40AF" />
                                        <TextBlock Text="{Binding ActiveCodeReferenceDesignerNote, Mode=OneWay}" TextWrapping="Wrap" Foreground="#475569" Margin="0,8,0,0" FontStyle="Italic" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Quick Reference Library" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding NfpaReferences}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Section, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Title, Mode=OneWay}" Foreground="#475569" Margin="0,2,0,4" />
                                                    <TextBlock Text="{Binding Summary, Mode=OneWay}" TextWrapping="Wrap" Foreground="#64748B" FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
